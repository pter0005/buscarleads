# ============================================
# SWAS LEADS — Variáveis de ambiente
# Renomeie para .env.local e preencha
# NUNCA commite este arquivo com valores reais
# ============================================

# Apify Token (obrigatório para busca real)
# Crie conta em https://apify.com e pegue em:
# Console > Settings > Integrations > API token
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXX

# Perplexity API Key (opcional - melhora o chat com IA)
# Crie em https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-XXXXXXXXXXXXXX
